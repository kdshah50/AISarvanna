# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth: OTP session JWT (≥32 random chars in production; keep stable across deploys)
JWT_SECRET=

# Twilio WhatsApp (required in production for OTP). Local dev may omit if send-otp allows dev flow.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# FastAPI backend (optional)
FASTAPI_INTERNAL_URL=https://your-fastapi.example.com
INTERNAL_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# App
NEXT_PUBLIC_APP_URL=https://www.example.com

# Admin UI/API (server only — do not use NEXT_PUBLIC_* for the PIN)
ADMIN_PIN=

# Vercel Cron: set the same value in the project’s CRON_SECRET; used as Bearer token for
# GET /api/cron/reconcile-payments (syncs pending Stripe checkouts to paid if webhook missed).
CRON_SECRET=
