# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth: OTP session JWT (≥32 random chars in production; keep stable across deploys)
JWT_SECRET=

# Twilio WhatsApp (required in production for OTP). Local dev may omit if send-otp allows dev flow.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# FastAPI backend (optional)
FASTAPI_INTERNAL_URL=https://your-fastapi.example.com
INTERNAL_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# IVA shown on marketplace cart (non-service). Default 16 (Mexico).
MARKETPLACE_VAT_PERCENT=16
# Cart: set true when Stripe Connect is ready (seller payouts). If unset/false, cart charges the platform account only.
MARKETPLACE_CONNECT_REQUIRED=

# App
# Canonical site URL (apex), no trailing slash — e.g. https://naranjogo.com.mx
NEXT_PUBLIC_APP_URL=https://naranjogo.com.mx

# Search: optional chat model for NL → price + keywords (default gpt-4o-mini). Same OPENAI_API_KEY as embeddings.
# SEARCH_PARSE_MODEL=gpt-4o-mini
# USD→MXN when user says dollars without pesos (default 17.5)
# SEARCH_MXN_PER_USD=17.5

# Optional: Sentry error monitoring (set in Vercel Production; leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=

# Admin UI/API (server only — do not use NEXT_PUBLIC_* for the PIN)
ADMIN_PIN=

# Vercel Cron: Bearer for GET /api/cron/reconcile-payments. vercel.json runs once daily
# (Hobby); use a per-minute/hourly schedule only on Pro+ or deploys can fail.
CRON_SECRET=
