# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://erfsvaddrspmlavvulne.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Required on the server: RLS is enabled on public tables; only the service role bypasses RLS. Never expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth (OTP session JWT — use a long random string in production; keep stable across deploys)
JWT_SECRET=change_me_to_a_long_random_secret

# Twilio WhatsApp (required in production). If unset locally, OTP is only logged + returned as devOtp.
# Sandbox: each user must message your sandbox From number and send the join code before they can receive OTPs.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# FastAPI backend (Railway)
FASTAPI_INTERNAL_URL=https://your-fastapi.railway.app
INTERNAL_API_SECRET=your_shared_secret_here

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# App
NEXT_PUBLIC_APP_URL=https://www.naranjogo.com.mx
